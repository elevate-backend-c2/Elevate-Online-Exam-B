    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\"name\":\"Ahmed\",\n\"email\":\"ahmed@mail.com\",\n\"password\":\"password123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/verify-email?token=EMAIL_TOKEN"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "pm.collectionVariables.set('accessToken', jsonData.accessToken);",
                  "}",
                  "if (jsonData.refreshToken) {",
                  "pm.collectionVariables.set('refreshToken', jsonData.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\"email\":\"ahmed@mail.com\",\n\"password\":\"password123\"\n}"
            }
          }
        },
        {
          "name": "Google Login",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/google"
          }
        },
        {
          "name": "Google Callback",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/google/callback"
          }
        },
        {
          "name": "Facebook Login",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/facebook"
          }
        },
        {
          "name": "Facebook Callback",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/facebook/callback"
          }
        },
        {
